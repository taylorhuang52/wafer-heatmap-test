@*
    ExplorerCanvas.razor
    單片晶圓 SVG 元件（Explorer 模式）。
    Die 格子較大（36px），格子內顯示讀值。
*@
@using WaferHeatmap.Shared
@using System.Linq

@if (Records == null || Records.Count == 0) { return; }

@{
    int xMin = Records.Min(r => r.X), xMax = Records.Max(r => r.X);
    int yMin = Records.Min(r => r.Y), yMax = Records.Max(r => r.Y);
    int gW = xMax - xMin + 1, gH = yMax - yMin + 1;
    int dW = gW * CELL, dH = gH * CELL;
    int waferPx = Math.Max(dW, dH) + 2 * MARGIN;
    int svgW = OUTER * 2 + waferPx;
    int svgH = OUTER * 2 + LABEL_H + waferPx;
    int cx   = OUTER + waferPx / 2;
    int cy   = OUTER + LABEL_H + waferPx / 2;
    int rad  = waferPx / 2;
    int dieOffX = OUTER + MARGIN + (waferPx - 2 * MARGIN - dW) / 2;
    int dieOffY = OUTER + LABEL_H + MARGIN + (waferPx - 2 * MARGIN - dH) / 2;

    var lookup = Records.ToDictionary(r => (r.X, r.Y));
}

<svg width="@svgW" height="@svgH" xmlns="http://www.w3.org/2000/svg"
     style="border:1px solid #ccc; background:white; border-radius:4px;">

    <!-- 標題 -->
    <svg:text x="@(svgW/2)" y="@(OUTER - 2)"
          text-anchor="middle" font-family="Arial" font-size="11"
          font-weight="bold" fill="#000099">#@WaferId  @ColumnName</svg:text>

    <!-- 晶圓背景 -->
    <circle cx="@cx" cy="@cy" r="@rad" fill="#bebebe"/>

    <!-- Die 格子 -->
    @for (int gy = 0; gy < gH; gy++)
    {
        for (int gx = 0; gx < gW; gx++)
        {
            int px  = dieOffX + gx * CELL;
            int py  = dieOffY + gy * CELL;
            int dx  = px + CELL / 2 - cx;
            int dy  = py + CELL / 2 - cy;
            double lim = rad - MARGIN / 2.0;
            if (dx * dx + dy * dy > lim * lim) continue;

            int dataX = xMin + gx, dataY = yMin + gy;
            if (!lookup.TryGetValue((dataX, dataY), out var rec)) continue;

            double? val    = ValueSelector(rec);
            string  bg     = ColorScale.GetCss(val, Lo, Hi);
            bool    light  = ColorScale.IsLightBackground(val, Lo, Hi);
            string  txtClr = light ? "#000000" : "#ffffff";
            string  txt    = val.HasValue && !double.IsNaN(val.Value)
                             ? FormatVal(val.Value) : "";

            <rect x="@(px+1)" y="@(py+1)"
                  width="@(CELL-2)" height="@(CELL-2)"
                  fill="@bg" stroke="#555" stroke-width="0.4"/>
            @if (!string.IsNullOrEmpty(txt))
            {
                <svg:text x="@(px + CELL/2)" y="@(py + CELL/2 + 3)"
                      text-anchor="middle" font-family="Arial"
                      font-size="@FontSize" fill="@txtClr">@txt</svg:text>
            }
        }
    }

    <!-- 外框 -->
    <circle cx="@cx" cy="@cy" r="@rad"
            fill="none" stroke="#444" stroke-width="1.5"/>
</svg>

@code {
    [Parameter, EditorRequired] public List<DieRecord>          Records    { get; set; } = new();
    [Parameter, EditorRequired] public Func<DieRecord, double?> ValueSelector { get; set; } = _ => null;
    [Parameter]                 public double                    Lo         { get; set; } = 0;
    [Parameter]                 public double                    Hi         { get; set; } = 1;
    [Parameter]                 public int                       WaferId    { get; set; }
    [Parameter]                 public string                    ColumnName { get; set; } = "";

    const int CELL    = 36;
    const int MARGIN  = 6;
    const int LABEL_H = 22;
    const int OUTER   = 14;
    int FontSize => CELL >= 30 ? 7 : 6;

    static string FormatVal(double v)
    {
        double a = Math.Abs(v);
        if (a >= 1000) return v.ToString("F0");
        if (a >= 100)  return v.ToString("F1");
        if (a >= 10)   return v.ToString("F2");
        if (a >= 1)    return v.ToString("F3");
        return v.ToString("G3");
    }
}
